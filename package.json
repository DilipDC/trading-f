{
  "name": "trading-platform",
  "version": "3.0.0",
  "description": "Professional Trading Platform - Real-time stock trading application with advanced charting, portfolio management, and order execution",
  "type": "module",
  "author": "DilipDC",
  "license": "MIT",
  "homepage": "https://trading-platform.onrender.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/DilipDC/trading-f.git"
  },
  "keywords": [
    "trading",
    "stocks",
    "investment",
    "portfolio",
    "real-time",
    "charting",
    "trading-platform",
    "stock-market",
    "react-trading",
    "zerodha-clone"
  ],
  "scripts": {
    "dev": "vite --host --port 3000",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "preview": "vite preview --port 3000",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules package-lock.json",
    "postinstall": "echo '✅ Dependencies installed successfully'"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "chart.js": "^4.4.0",
    "react-chartjs-2": "^5.2.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^3.0.0",
    "clsx": "^2.0.0",
    "react-hot-toast": "^2.4.1",
    "react-spinners": "^0.13.8",
    "uuid": "^9.0.1",
    "axios": "^1.6.2",
    "framer-motion": "^10.16.16",
    "react-icons": "^4.12.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/node": "^20.10.4",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.8",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3",
    "gh-pages": "^6.1.0",
    "terser": "^5.26.0"
  },
  "engines": {
    "node": "20.18.0",
    "npm": "10.8.2"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "not ie 11"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "volta": {
    "node": "20.18.0",
    "npm": "10.8.2"
  }
}
