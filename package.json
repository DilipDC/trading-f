{
  "name": "trading-platform",
  "version": "2.0.0",
  "description": "Professional Trading Platform - Real-time stock trading application",
  "type": "module",
  "author": "Your Name",
  "license": "MIT",
  "homepage": "https://YOUR_USERNAME.github.io/trading-app",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/trading-app.git"
  },
  "scripts": {
    "dev": "vite --host --port 3000",
    "build": "vite build",
    "build:prod": "tsc && vite build --mode production",
    "preview": "vite preview --port 3000",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "deploy:clean": "gh-pages -d dist -t true",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules package-lock.json",
    "postinstall": "echo '✅ Dependencies installed successfully'"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-spinners": "^0.13.8",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "gh-pages": "^6.3.0",
    "prettier": "^3.1.0",
    "terser": "^5.26.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
